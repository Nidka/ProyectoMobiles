<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    tools:context=".LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="40dp"
        android:paddingBottom="32dp">

        <!-- UPNGO Logo (complete from SVG) -->
        <ImageView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:contentDescription="UPNGO Logo"
            android:scaleType="fitCenter"
            android:src="@drawable/app_logo_vector" />

        <!-- Welcome Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/login_welcome"
            android:textColor="@color/text_heading"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/login_subtitle"
            android:textColor="@color/text_body"
            android:textSize="15sp" />

        <!-- Login preview (hidden by default, shown when email matches) -->
        <LinearLayout
            android:id="@+id/layout_login_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iv_login_avatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_avatar_circle"
                android:contentDescription="@string/profile_photo"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_avatar_placeholder" />

            <TextView
                android:id="@+id/tv_login_preview_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:textColor="@color/text_heading"
                android:textStyle="bold"
                tools:text="Cuenta detectada" />
        </LinearLayout>

        <!-- Email Field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/label_email"
            android:textColor="@color/text_heading"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="Email"
                android:src="@drawable/ic_mail_outline" />

            <EditText
                android:id="@+id/et_login_email"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_heading"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Password Field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/label_password"
            android:textColor="@color/text_heading"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="Password"
                android:src="@drawable/ic_lock_outline" />

            <EditText
                android:id="@+id/et_login_password"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:textColor="@color/text_heading"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/iv_toggle_password"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Toggle password"
                android:src="@drawable/ic_eye" />
        </LinearLayout>

        <!-- Forgot Password -->
        <TextView
            android:id="@+id/tv_forgot_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="10dp"
            android:text="@string/forgot_password"
            android:textColor="@color/upn_yellow"
            android:textSize="14sp"
            android:textStyle="italic" />

        <!-- Login Button -->
        <TextView
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_yellow"
            android:stateListAnimator="@animator/button_scale"
            android:elevation="6dp"
            android:gravity="center"
            android:text="@string/action_login"
            android:textColor="@color/text_on_yellow"
            android:textSize="17sp"
            android:textStyle="bold" />

        <!-- Divider with O -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/divider_color" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:text="O"
                android:textColor="@color/text_body"
                android:textSize="14sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/divider_color" />
        </LinearLayout>

        <!-- Create Account Button (Outlined) -->
        <TextView
            android:id="@+id/tv_go_register"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_outlined_yellow"
            android:stateListAnimator="@animator/button_scale"
            android:gravity="center"
            android:text="@string/action_create_account"
            android:textColor="@color/upn_yellow"
            android:textSize="17sp"
            android:textStyle="bold" />

        <!-- Divider Síguenos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/divider_color" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="14dp"
                android:text="Síguenos"
                android:textColor="@color/text_hint"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/divider_color" />
        </LinearLayout>

        <!-- Social media buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_social_facebook"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="Facebook UPN"
                android:foreground="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_social_facebook" />

            <ImageView
                android:id="@+id/btn_social_instagram"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="24dp"
                android:contentDescription="Instagram UPN"
                android:foreground="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_social_instagram" />

            <ImageView
                android:id="@+id/btn_social_youtube"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="YouTube UPN"
                android:foreground="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_social_youtube" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
