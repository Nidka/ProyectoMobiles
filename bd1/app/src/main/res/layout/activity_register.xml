<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    tools:context=".RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- Header: Back arrow + Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_back"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="Volver"
                android:padding="4dp"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/register_title"
                android:textColor="@color/text_heading"
                android:textSize="26sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Register As Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/register_as"
            android:textColor="@color/text_heading"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Tabs: Estudiante / Conductor -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_tab_container"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="4dp">

            <LinearLayout
                android:id="@+id/tab_student"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_active"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_tab_student"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="Estudiante"
                    android:src="@drawable/ic_person_outline"
                    android:tint="@color/text_on_yellow" />

                <TextView
                    android:id="@+id/tv_tab_student"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/tab_student"
                    android:textColor="@color/text_on_yellow"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_driver"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_inactive"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_tab_driver"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="Conductor"
                    android:src="@drawable/ic_bus"
                    android:tint="@color/text_heading" />

                <TextView
                    android:id="@+id/tv_tab_driver"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/tab_driver"
                    android:textColor="@color/text_heading"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Community text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:textColor="@color/text_body"
            android:textSize="14sp">
        </TextView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Únete a la comunidad "
                android:textColor="@color/text_body"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UPN"
                android:textColor="@color/upn_yellow"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Go"
                android:textColor="@color/text_heading"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Nombres Field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/label_first_name"
            android:textColor="@color/text_heading"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="Nombres"
                android:src="@drawable/ic_person_outline" />

            <EditText
                android:id="@+id/et_register_first_name"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="@string/hint_first_name"
                android:inputType="textCapWords"
                android:textColor="@color/text_heading"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Apellidos Field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_last_name"
            android:textColor="@color/text_heading"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="Apellidos"
                android:src="@drawable/ic_person_outline" />

            <EditText
                android:id="@+id/et_register_last_name"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="@string/hint_last_name"
                android:inputType="textCapWords"
                android:textColor="@color/text_heading"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Correo Field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_register_email"
            android:textColor="@color/text_heading"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="Correo"
                android:src="@drawable/ic_mail_outline" />

            <EditText
                android:id="@+id/et_register_email"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="@string/hint_register_email"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_heading"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Contraseña Field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_password"
            android:textColor="@color/text_heading"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="Contraseña"
                android:src="@drawable/ic_lock_outline" />

            <EditText
                android:id="@+id/et_register_password"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:textColor="@color/text_heading"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Confirmar Contraseña Field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_password_confirm"
            android:textColor="@color/text_heading"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="Confirmar Contraseña"
                android:src="@drawable/ic_lock_outline" />

            <EditText
                android:id="@+id/et_register_password_confirm"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="@string/hint_password_confirm"
                android:inputType="textPassword"
                android:textColor="@color/text_heading"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Register Button -->
        <TextView
            android:id="@+id/btn_register"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_button_yellow"
            android:stateListAnimator="@animator/button_scale"
            android:elevation="6dp"
            android:gravity="center"
            android:text="@string/action_register"
            android:textColor="@color/text_on_yellow"
            android:textSize="17sp"
            android:textStyle="bold" />

        <!-- Terms text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Al registrarte aceptas los "
                android:textColor="@color/text_body"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_terms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/terms_link"
                android:textColor="@color/upn_yellow"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
