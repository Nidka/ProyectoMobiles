<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    tools:context=".ResetPasswordActivity">

    <LinearLayout
        android:id="@+id/layout_reset_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- Header: Back arrow + Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_reset_back"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="Volver"
                android:padding="4dp"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Recuperar Cuenta"
                android:textColor="@color/text_heading"
                android:textSize="26sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:id="@+id/iv_reset_logo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:contentDescription="UPNGo Logo"
            android:scaleType="fitCenter"
            android:src="@drawable/app_logo_vector" />

        <TextView
            android:id="@+id/tv_reset_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:text="Restablecer contraseña"
            android:textColor="@color/text_heading"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_reset_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Escribe tu correo y te enviaremos un enlace para crear una nueva contraseña."
            android:textColor="@color/text_body"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp" />

        <!-- Correo Field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Correo institucional"
            android:textColor="@color/text_heading"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="Correo"
                android:src="@drawable/ic_mail_outline"
                android:tint="@color/text_hint" />

            <EditText
                android:id="@+id/et_reset_email"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="n00123456@upn.pe"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_heading"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Send Button -->
        <TextView
            android:id="@+id/btn_send_reset"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_button_yellow"
            android:stateListAnimator="@animator/button_scale"
            android:elevation="6dp"
            android:gravity="center"
            android:text="Enviar enlace"
            android:textColor="@color/text_on_yellow"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_reset_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="Si no lo ves en tu bandeja de entrada, revisa tu carpeta de correo no deseado (spam)."
            android:textColor="@color/text_body"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>
</ScrollView>
