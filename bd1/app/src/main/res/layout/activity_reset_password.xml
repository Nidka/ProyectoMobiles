<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    tools:context=".feature.auth.ui.activity.ResetPasswordActivity">

    <!-- STATE 1: Input form -->
    <ScrollView
        android:id="@+id/layout_reset_input"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/layout_reset_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_reset_back"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="Volver"
                    android:padding="4dp"
                    android:src="@drawable/ic_arrow_back" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Recuperar Cuenta"
                    android:textColor="@color/text_heading"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/iv_reset_logo"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:contentDescription="UPNGo Logo"
                android:scaleType="fitCenter"
                android:src="@drawable/app_logo_vector" />

            <TextView
                android:id="@+id/tv_reset_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:text="Restablecer contraseña"
                android:textColor="@color/text_heading"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_reset_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Escribe tu correo y te enviaremos un enlace para crear una nueva contraseña."
                android:textColor="@color/text_body"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Correo institucional"
                android:textColor="@color/text_heading"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="Correo"
                    android:src="@drawable/ic_mail_outline"
                    android:tint="@color/text_hint" />

                <EditText
                    android:id="@+id/et_reset_email"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="n00123456@upn.pe"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/text_heading"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_send_reset"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_button_yellow"
                android:elevation="6dp"
                android:gravity="center"
                android:stateListAnimator="@animator/button_scale"
                android:text="Enviar enlace"
                android:textColor="@color/text_on_yellow"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_reset_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="Si no lo ves en tu bandeja de entrada, revisa tu carpeta de correo no deseado (spam)."
                android:textColor="@color/text_body"
                android:textSize="13sp" />

        </LinearLayout>
    </ScrollView>

    <!-- STATE 2: Confirmation screen -->
    <LinearLayout
        android:id="@+id/layout_reset_confirm"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_primary"
        android:orientation="vertical"
        android:visibility="gone">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp"
                android:paddingHorizontal="28dp"
                android:paddingTop="20dp">

                <ImageView
                    android:id="@+id/iv_confirm_back"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="Volver"
                    android:padding="4dp"
                    android:src="@drawable/ic_arrow_back" />

                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="36dp"
                    android:background="@drawable/bg_badge_yellow">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center"
                        android:contentDescription="Correo enviado"
                        android:src="@drawable/ic_mail_outline"
                        android:tint="@color/white" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="28dp"
                    android:text="Revisa tu Correo"
                    android:textColor="@color/text_heading"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:text="Te hemos enviado un enlace para restablecer tu contraseña. Haz click en el enlace para crear una nueva."
                    android:textColor="@color/text_body"
                    android:textSize="15sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Correo"
                        android:src="@drawable/ic_mail_outline"
                        android:tint="@color/text_hint" />

                    <TextView
                        android:id="@+id/tv_confirm_email"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/text_heading"
                        android:textSize="15sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Instrucciones:"
                    android:textColor="@color/text_heading"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"
                    android:text="1. Revisa tu bandeja de entrada"
                    android:textColor="@color/text_body"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp"
                    android:text="2. Busca el correo de UPNGo"
                    android:textColor="@color/text_body"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp"
                    android:text="3. Haz click en el enlace para restablecer"
                    android:textColor="@color/text_body"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp"
                    android:text="4. Regresa aquí o inicia sesión"
                    android:textColor="@color/text_body"
                    android:textSize="14sp" />

            </LinearLayout>
        </ScrollView>

        <TextView
            android:id="@+id/btn_go_login"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_button_yellow"
            android:elevation="6dp"
            android:gravity="center"
            android:stateListAnimator="@animator/button_scale"
            android:text="Ir al Login"
            android:textColor="@color/text_on_yellow"
            android:textSize="17sp"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>
