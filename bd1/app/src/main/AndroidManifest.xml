<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".ProyectoMovilesApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Bd1"
        tools:targetApi="31">

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
        <activity
            android:name=".feature.auth.ui.activity.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".feature.products.ui.activity.MainActivity"
            android:exported="false" />
        <activity
            android:name=".feature.auth.ui.activity.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".feature.products.ui.activity.ProductFormActivity"
            android:exported="false" />
        <activity
            android:name=".feature.profile.ui.activity.ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".feature.auth.ui.activity.ResetPasswordActivity"
            android:exported="false" />
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Bd1.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>